@page "/inventory"
@using WorkshopAdmin.Shared.Dtos.Parts
@using WorkshopAdmin.UI.Components.Inventory
@using WorkshopAdmin.UI.Components.Clients
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <MudText Typo="Typo.h4" Class="fw-bold" Style="color: #000666;">
                Inventory & Parts
            </MudText>

            <MudText Typo="Typo.body2" Class="text-secondary">
                Manage component stock levels, pricing, and technical catalog.
            </MudText>
        </div>

        <!-- BUTTONS -->
        <div class="d-flex gap-2">

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Description"
                       Class="py-2 px-3 fw-bold"
                       Style="text-transform: none; border-radius: 4px; border-color: var(--slate-200); color: #000666;">
                Create Report
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="OpenCreatePartDialog"
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="py-2 px-3 fw-bold"
                       Style="text-transform: none; border-radius: 4px;">
                Add New Part
            </MudButton>

        </div>

    </div>

    <!-- STATS -->
    <InventoryStats />

    <MudGrid>

        <MudItem xs="12" lg="12">

            <InventoryFilters />

            <!-- TABLE -->
            <MudPaper Elevation="0" Class="border rounded-4 overflow-hidden">

                <InventoryTable ReloadTrigger="_reloadFlag" />

            </MudPaper>

        </MudItem>

    </MudGrid>

</MudContainer>
@code {
    private bool _reloadFlag;
    private async Task OpenCreatePartDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<CreatePartDialog>(" ", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is PartDto newPart)
        {
            _reloadFlag = !_reloadFlag;
            Snackbar.Add($"Part {newPart.Name} added to the system.", Severity.Success);           
        }
    }
}