@page "/orders"
@using WorkshopAdmin.Shared.Dtos
@using WorkshopAdmin.Shared.Dtos.ServiceOrders
@using WorkshopAdmin.UI.Components.ServiceOrders
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-1">
    @* Header Section *@
    <div class="d-flex justify-space-between align-center mb-8">
        <div>
            <MudText Typo="Typo.h4" Class="font-black tracking-tighter" Style="color: #000666;">Gestión de Órdenes de Servicio</MudText>
            <MudText Typo="Typo.body2" Class="text-slate-500">Panel operativo de reparaciones y diagnósticos técnicos.</MudText>
        </div>
        
        @* Button Group *@
        <div class="d-flex gap-3">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Description"
                       Class="py-2 px-4 font-bold"
                       Style="text-transform: none; border-radius: 4px; border-color: var(--slate-200); color: #000666;">
                Create Report
            </MudButton>
            
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="py-2 px-4 shadow-none font-bold"
                       Style="text-transform: none; border-radius: 4px;">
                Add New Service Order
            </MudButton>
        </div>
    </div>
    @* Statistics Grid *@
   <ServiceOrderStats/>

    <MudGrid>
        @* Main Content (Table and Filters) *@
        <MudItem xs="12" lg="12">
            @* <ClientFilters /> *@
            
            @* Aquí va tu MudDataGrid de Clientes *@
            <MudPaper Elevation="0" Class="border border-slate-200 overflow-hidden">
                @* ... Tu componente MudDataGrid ... *@
                <ServiceOrderTable/>
            </MudPaper>
        </MudItem>

    </MudGrid>
</MudContainer>
