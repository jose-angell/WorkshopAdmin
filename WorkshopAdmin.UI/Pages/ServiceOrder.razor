@page "/orders"
@using WorkshopAdmin.Shared.Dtos
@using WorkshopAdmin.Shared.Dtos.ServiceOrders
@using WorkshopAdmin.UI.Components.ServiceOrders
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">

    @* Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <MudText Typo="Typo.h4"
                     Class="fw-bold"
                     Style="color: #000666;">
                Gestión de Órdenes de Servicio
            </MudText>

            <MudText Typo="Typo.body2"
                     Class="text-muted">
                Panel operativo de reparaciones y diagnósticos técnicos.
            </MudText>
        </div>

        @* Button Group *@
        <div class="d-flex gap-2">

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Description"
                       Class="fw-bold px-3 py-2"
                       Style="text-transform: none; border-radius: 4px; border-color: #dee2e6; color: #000666;">
                Create Report
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="/service-orders/create"
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="fw-bold px-3 py-2"
                       Style="text-transform: none; border-radius: 4px;">
                Add New Service Order
            </MudButton>

        </div>

    </div>

    @* Statistics *@
    <ServiceOrderStats />

    <MudGrid>

        <MudItem xs="12">

            <MudPaper Elevation="0" Class="border rounded overflow-hidden">

                <ServiceOrderTable />

            </MudPaper>

        </MudItem>

    </MudGrid>

</MudContainer>