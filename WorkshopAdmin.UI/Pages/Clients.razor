@page "/clients"
@using WorkshopAdmin.Shared.Dtos
@using WorkshopAdmin.Shared.Dtos.Customers
@using WorkshopAdmin.UI.Components.Clients
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    @* Header Section *@
    <div class="d-flex justify-space-between align-center mb-8">
        <div>
            <MudText Typo="Typo.h4" Class="font-black tracking-tighter" Style="color: #000666;">Clients</MudText>
            <MudText Typo="Typo.body2" Class="text-slate-500">Manage your customer database and service history.</MudText>
        </div>
        
        @* Button Group *@
        <div class="d-flex gap-3">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Description"
                       Class="py-2 px-4 font-bold"
                       Style="text-transform: none; border-radius: 4px; border-color: var(--slate-200); color: #000666;">
                Create Report
            </MudButton>
            
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="OpenCreateCustomerDialog"
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="py-2 px-4 shadow-none font-bold"
                       Style="text-transform: none; border-radius: 4px;">
                Add New Client
            </MudButton>
        </div>
    </div>
    @* Statistics Grid *@
    <ClientStats />

    <MudGrid>
        @* Main Content (Table and Filters) *@
        <MudItem xs="12" lg="12">
            <ClientFilters />
            
            @* Aquí va tu MudDataGrid de Clientes *@
            <MudPaper Elevation="0" Class="border border-slate-200 overflow-hidden">
                @* ... Tu componente MudDataGrid ... *@
                    <ClientTable/>
            </MudPaper>
        </MudItem>

    </MudGrid>
</MudContainer>


@code {
    private async Task OpenCreateCustomerDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<CreateCustomerDialog>(" ", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CreateCustomerRequest newClient)
        {
            try
            {
                // Aquí es donde conectas con tu servicio de aplicación
                // await CustomerService.CreateAsync(newClient);
                
                Snackbar.Add($"Client {newClient.Name} added to the system.", Severity.Success);
                
                // Opcional: Recargar la lista de la tabla
                // await LoadClients();
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error saving client: " + ex.Message, Severity.Error);
            }
        }
    }
}