@page "/clients"
@using WorkshopAdmin.Shared.Dtos
@using WorkshopAdmin.Shared.Dtos.Customers
@using WorkshopAdmin.UI.Components.Clients
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-1">

    @* Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <MudText Typo="Typo.h4" Class="fw-bold" Style="color: #000666;">
                Clients
            </MudText>

            <MudText Typo="Typo.body2" Class="text-muted">
                Manage your customer database and service history.
            </MudText>
        </div>

        @* Button Group *@
        <div class="d-flex" style="gap: 0.75rem;">

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Description"
                       Class="py-2 px-4 fw-bold"
                       Style="text-transform: none; border-radius: 4px; border-color: #dee2e6; color: #000666;">
                Create Report
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="OpenCreateCustomerDialog"
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="py-2 px-4 fw-bold"
                       Style="text-transform: none; border-radius: 4px;">
                Add New Client
            </MudButton>

        </div>
    </div>

    @* Statistics Grid *@
    <ClientStats />

    <MudGrid>
        @* Main Content *@
        <MudItem xs="12" lg="12">

            <ClientFilters />

            <MudPaper Elevation="0" Class="rounded-4 border overflow-hidden" Style="border-color: #dee2e6;">
                <ClientTable @ref="_clientTable" />
            </MudPaper>

        </MudItem>
    </MudGrid>

</MudContainer>
@code {
    private ClientTable _clientTable = default!;

    private async Task OpenCreateCustomerDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<CreateCustomerDialog>(" ", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CustomerDto newClient)
        {
            await _clientTable.LoadDataClient();
            Snackbar.Add($"Client {newClient.Name} added to the system.", Severity.Success);
        }
    }
}