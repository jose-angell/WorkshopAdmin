@* Components/Equipment/EquipmentFilters.razor *@
<MudPaper Elevation="0" Class="p-4 rounded-4 border bg-white mb-4">

    <MudGrid Spacing="3" Class="align-items-center">

        <!-- SEARCH -->
        <MudItem xs="12" sm="6" md="4">
            <MudTextField T="string"
                          Placeholder="Search parts by name, SKU or category..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="bg-light w-100" />
        </MudItem>

        <!-- STATUS -->
        <MudItem xs="12" sm="3" md="2">
            <MudSelect T="string"
                       Label="Status"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="bg-light w-100">

                <MudSelectItem Value="@("All")">All Parts</MudSelectItem>
                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem Value="@("Inactive")">Inactive</MudSelectItem>

            </MudSelect>
        </MudItem>

        <!-- BUTTON -->
        <MudItem xs="12" sm="3" md="2">
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.FilterList"
                       FullWidth="true"
                       Class="w-100"
                       Style="height: 40px; text-transform: none;">

                More Filters

            </MudButton>
        </MudItem>

    </MudGrid>

</MudPaper>