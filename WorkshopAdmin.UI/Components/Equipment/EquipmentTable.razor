@using MudBlazor
@using WorkshopAdmin.Shared.Dtos.Equipments
@using WorkshopAdmin.Shared.Enums
@inject IDialogService DialogService
@inject ISnackbar Snackbar



    <MudDataGrid T="EquipmentDto"
                 Items="_equipment"
                 Dense="true"
                 Hover="true"
                 Bordered="false"
                 Striped="false"
                 Elevation="0">

        <Columns>

            <!-- TYPE & DESCRIPTION -->
            <TemplateColumn Title="TYPE & DESCRIPTION">
                <CellTemplate>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2" Class="fw-bold text-primary">
                            @context.Item.TypeName
                        </MudText>

                        <MudText Typo="Typo.caption" Class="text-secondary">
                            @context.Item.DescriptionType
                        </MudText>
                    </div>
                </CellTemplate>
            </TemplateColumn>

            <!-- BRAND -->
            <PropertyColumn Property="x => x.Brand" Title="BRAND" />

            <!-- MODEL -->
            <PropertyColumn Property="x => x.Model" Title="MODEL" />

            <!-- TECHNICAL SPECIFICATIONS -->
            <TemplateColumn Title="TECHNICAL SPECIFICATIONS">
                <CellTemplate>
                    <MudPaper Class="p-2 rounded bg-light">
                        <MudText Typo="Typo.caption">
                            @context.Item.TechnicalSpecifications
                        </MudText>
                    </MudPaper>
                </CellTemplate>
            </TemplateColumn>

            <!-- STATUS -->
            <TemplateColumn Title="STATUS" Align="Align.Center">
                <CellTemplate>
                    <MudChip Size="Size.Small"
                             Variant="Variant.Filled"
                             Color="@GetStatusColor(context.Item)">
                        @GetStatusText(context.Item)
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            <!-- ACTIONS -->
            <TemplateColumn Title="ACTIONS" Align="Align.Right">
                <CellTemplate>
                    <div class="d-flex justify-content-end gap-1">

                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenEditDialog(context.Item))" />

                        <MudIconButton Icon="@Icons.Material.Filled.History"
                                       Size="Size.Small"
                                       OnClick="@(() => OnHistory.InvokeAsync(context.Item))" />

                        <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                       Size="Size.Small"
                                       OnClick="@(() => OnManage.InvokeAsync(context.Item))" />

                    </div>
                </CellTemplate>
            </TemplateColumn>

        </Columns>

        <!-- EMPTY -->
        <NoRecordsContent>
            <MudText Class="p-4">No equipment found</MudText>
        </NoRecordsContent>

        <!-- PAGER -->
        <PagerContent>
            <MudStack Row Justify="Justify.SpaceBetween"
                      AlignItems="AlignItems.Center"
                      Class="p-3">

                <MudText Typo="Typo.caption">
                    Showing @($"{_from}-{_to} of {_equipment.Count} items")
                </MudText>

                <MudDataGridPager T="EquipmentDto" />

            </MudStack>
        </PagerContent>

    </MudDataGrid>



@code {

    [Parameter] public List<EquipmentDto> _equipment { get; set; } = new List<EquipmentDto>();

    
    [Parameter] public EventCallback<EquipmentDto> OnEdit { get; set; }
    [Parameter] public EventCallback<EquipmentDto> OnHistory { get; set; }
    [Parameter] public EventCallback<EquipmentDto> OnManage { get; set; }

    
    private int _currentPage = 0;
    private int _rowsPerPage = 5;

    private int _from => (_currentPage * _rowsPerPage) + 1;
    private int _to => Math.Min((_currentPage + 1) * _rowsPerPage, _equipment.Count);

   

    private Color GetStatusColor(EquipmentDto item)
    {
        if (!item.IsActive)
            return Color.Error;

        return Color.Success;
    }

    private string GetStatusText(EquipmentDto item)
    {
        if (!item.IsActive)
            return "Decommissioned";

        return "Active";
    }
    protected override void OnInitialized()
    {
        _equipment = new List<EquipmentDto>()
        {
            new()
            {
                Id = Guid.NewGuid(),
                TypeId = EquipmentType.Industrial,
                TypeName = EquipmentType.Industrial.ToFriendlyName(),
                DescriptionType = "Heavy-duty assembly tool",
                Brand = "Ingersoll Rand",
                Model = "2235TiMAX",
                TechnicalSpecifications = "Max Torque: 1,350 ft-lb; Weight: 4.6 lbs; Air Consumption: 6 cfm",
                IsActive = true,
                CreatedAt = DateTimeOffset.Now.AddDays(-10)
            },
            new()
            {
                Id = Guid.NewGuid(),
                TypeId = EquipmentType.Agricultural,
                TypeName = EquipmentType.Agricultural.ToFriendlyName(),
                DescriptionType = "Metalworking precision tool",
                Brand = "Precision Matched",
                Model = "PM-1236",
                TechnicalSpecifications = "12\" Swing; 36\" Center; 1.5HP Motor; D1-4 Camlock Spindle",
                IsActive = true,
                CreatedAt = DateTimeOffset.Now.AddDays(-30)
            },
            new()
            {
                Id = Guid.NewGuid(),
                TypeId = EquipmentType.PowerTool,
                TypeName = EquipmentType.PowerTool.ToFriendlyName(),
                DescriptionType = "Fabrication machinery",
                Brand = "Sunex Tools",
                Model = "SUN5720",
                TechnicalSpecifications = "20-Ton Capacity; H-Frame Design; Adjustable Bed; Floor Mount",
                IsActive = true,
                CreatedAt = DateTimeOffset.Now.AddDays(-5)
            },
            new()
            {
                Id = Guid.NewGuid(),
                TypeId = EquipmentType.LightVehicle,
                TypeName = EquipmentType.LightVehicle.ToFriendlyName(),
                DescriptionType = "Vehicle electronic analyzer",
                Brand = "Autel",
                Model = "MaxiSys Elite",
                TechnicalSpecifications = "WiFi/Bluetooth; 9.7\" Retina; OE-Level Coverage; 2GB RAM",
                IsActive = false,
                CreatedAt = DateTimeOffset.Now.AddDays(-60)
            },
            new()
            {
                Id = Guid.NewGuid(),
                TypeId = EquipmentType.Unknown,
                TypeName = EquipmentType.Unknown.ToFriendlyName(),
                DescriptionType = "Electrical diagnostic tool",
                Brand = "Midtronics",
                Model = "MDX-650",
                TechnicalSpecifications = "12V/24V Systems; Conductance Technology; Digital Display",
                IsActive = true,
                CreatedAt = DateTimeOffset.Now.AddDays(-15)
            }
        };
    }

    private async Task OpenEditDialog(EquipmentDto equipment)
    {
        // 1. Mapeamos el DTO al modelo de edición
        var updateRequest = new UpdateEquipmentRequest
        {
            Id = equipment.Id,
            TypeId = equipment.TypeId,
            DescriptionType = equipment.DescriptionType,
            Model = equipment.Model,
            Brand = equipment.Brand,
            TechnicalSpecifications = equipment.TechnicalSpecifications,
            IsActive = equipment.IsActive
        };

        var parameters = new DialogParameters<EditEquipmentDialog>
        {
            { x => x.InitialData, updateRequest }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            BackdropClick = false // Evita que se cierre por error al dar click fuera
        };

        var dialog = await DialogService.ShowAsync<EditEquipmentDialog>(" ", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is UpdateEquipmentRequest updated)
        {
            // 2. Aquí llamarías a tu servicio: await EquipmentService.UpdateAsync(updated);

            // 3. Actualizamos la lista local para que la UI refleje el cambio inmediatamente
            var equipmentInList = _equipment.FirstOrDefault(c => c.Id == updated.Id);
            if (equipmentInList != null)
            {
                equipmentInList.DescriptionType = updated.DescriptionType;
                equipmentInList.Model = updated.Model;
                equipmentInList.Brand = updated.Brand;
                equipmentInList.TechnicalSpecifications = updated.TechnicalSpecifications;
                equipmentInList.TypeId = updated.TypeId;
                equipmentInList.TypeName = updated.TypeId.ToFriendlyName();
                equipmentInList.IsActive = updated.IsActive;
                
                Snackbar.Add("Equipo actualizado correctamente", Severity.Success);
                StateHasChanged(); // Forzamos el renderizado del DataGrid
            }
        }
    }
}