@using MudBlazor

<MudGrid Class="mb-4">

    <!-- ===================== -->
    <!-- TOTAL PARTS -->
    <!-- ===================== -->
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="1"
                  Class="p-4 rounded-4 border d-flex flex-column"
                  Style="background-color: var(--mud-palette-surface);">

            <!-- TOP -->
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">

                <!-- ICON -->
                <MudPaper Class="p-2 rounded d-flex"
                          Style="background-color: var(--mud-palette-primary-light); color: var(--mud-palette-primary);">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                </MudPaper>

                <!-- DELTA -->
                <MudChip T="string"
                         Color="Color.Success"
                         Variant="Variant.Filled"
                         Size="Size.Small"
                         Class="fw-bold">
                    +12%
                </MudChip>

            </MudStack>

            <!-- LABEL -->
            <MudText Typo="Typo.overline"
                     Class="text-uppercase fw-bold text-secondary">
                Total Parts
            </MudText>

            <!-- VALUE -->
            <MudText Typo="Typo.h5" Class="fw-bold">
                2,842
            </MudText>

        </MudPaper>
    </MudItem>


    <!-- ===================== -->
    <!-- LOW STOCK -->
    <!-- ===================== -->
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="1"
                  Class="p-4 rounded-4 border d-flex flex-column"
                  Style="
            background-color: var(--mud-palette-surface);
            border-color: var(--mud-palette-error);
            box-shadow: 0 0 0 2px rgba(186, 26, 26, 0.2);
            ">

            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">

                <!-- ICON -->
                <MudPaper Class="p-2 rounded d-flex"
                          Style="background-color: rgba(102,0,0,0.22); color: rgb(102,0,39);">
                    <MudIcon Icon="@Icons.Material.Filled.Warning"
                             Color="Color.Error"
                             Style="opacity:0.6;" />
                </MudPaper>

                <!-- STATUS -->
                <MudChip T="string"
                         Color="Color.Error"
                         Variant="Variant.Filled"
                         Size="Size.Small"
                         Class="fw-bold">
                    Action Required
                </MudChip>

            </MudStack>

            <MudText Typo="Typo.overline"
                     Class="text-uppercase fw-bold text-secondary">
                Low Stock Alerts
            </MudText>

            <MudText Typo="Typo.h5" Class="fw-bold">
                18
            </MudText>

        </MudPaper>
    </MudItem>


    <!-- ===================== -->
    <!-- INVENTORY VALUE -->
    <!-- ===================== -->
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="1"
                  Class="p-4 rounded-4 border d-flex flex-column"
                  Style="background-color: var(--mud-palette-surface);">

            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">

                <MudPaper Class="p-2 rounded d-flex"
                          Style="background-color: rgba(0,102,102,0.1); color: rgb(0,102,64);">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet"
                             Style="opacity:0.6;" />
                </MudPaper>

            </MudStack>

            <MudText Typo="Typo.overline"
                     Class="text-uppercase fw-bold text-secondary">
                Inventory Value
            </MudText>

            <MudText Typo="Typo.h5" Class="fw-bold">
                @TotalValue.ToString("C")
            </MudText>

        </MudPaper>
    </MudItem>


    <!-- ===================== -->
    <!-- ORDERS -->
    <!-- ===================== -->
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="1"
                  Class="p-4 rounded-4 border d-flex flex-column"
                  Style="background-color: var(--mud-palette-surface);">

            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">

                <MudPaper Class="p-2 rounded d-flex"
                          Style="background-color: rgba(0,102,102,0.1); color: var(--mud-palette-primary);">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" />
                </MudPaper>

            </MudStack>

            <MudText Typo="Typo.overline"
                     Class="text-uppercase fw-bold text-secondary">
                Orders
            </MudText>

            <MudText Typo="Typo.h5" Class="fw-bold">
                10
            </MudText>

        </MudPaper>
    </MudItem>

</MudGrid>

@code {
    
    public decimal TotalValue { get; set; } = 142500;
}