@using MudBlazor
@using WorkshopAdmin.Shared.Dtos.Parts
@using WorkshopAdmin.UI.Services
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject InventoryClient InventoryClient


<MudDataGrid T="PartDto"
             Items="@PartsList"
             Loading="@_loading"
             Dense="true"
             Hover="true"
             Elevation="0"
             Filterable="true"
             QuickFilter="@_quickFilter"
             RowsPerPage="5">

    <Columns>

        <!-- SKU / BRAND -->
        <TemplateColumn Title="SKU / Brand" Filterable="true">
            <CellTemplate Context="context">
                @{
                    var item = context.Item;
                }
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption">@item.Sku</MudText>
                    <MudText Typo="Typo.body2">@item.Brand</MudText>
                </MudStack>
            </CellTemplate>
        </TemplateColumn>

        <!-- NAME -->
        <TemplateColumn Title="Part Name" Filterable="true">
            <CellTemplate Context="context">
                <MudText Class="fw-bold">@context.Item.Name</MudText>
            </CellTemplate>
        </TemplateColumn>

        <!-- CATEGORY -->
        <TemplateColumn Title="Category">
            <CellTemplate Context="context">
                <MudChip T="string" Size="Size.Small">
                    @context.Item.CategoryName
                </MudChip>
            </CellTemplate>
        </TemplateColumn>

        <!-- STOCK -->
        <TemplateColumn Title="Stock" Align="Align.Center">
            <CellTemplate Context="context">
                @{
                    var item = context.Item;
                    var isLow = item.Stock <= item.MinStock;
                }

                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="1">

                    @if (isLow)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Warning"
                                 Color="Color.Error"
                                 Size="Size.Small" />
                    }

                    <MudText Color="@(isLow ? Color.Error : Color.Default)">
                        @item.Stock
                    </MudText>

                    <MudText Typo="Typo.caption">
                        @item.UnitOfMeasure
                    </MudText>

                </MudStack>
            </CellTemplate>
        </TemplateColumn>

        <!-- PRICE -->
        <PropertyColumn Property="x => x.Price"
                        Title="Price"
                        Align="Align.Right"
                        Format="C"
                        Filterable="false" />

        <!-- LOCATION -->
        <TemplateColumn Title="Location">
            <CellTemplate Context="context">
                <MudChip T="string"
                         StartIcon="@Icons.Material.Filled.LocationOn"
                         Size="Size.Small">
                    @context.Item.WarehouseLocation
                </MudChip>
            </CellTemplate>
        </TemplateColumn>

        <!-- STATUS -->
        <TemplateColumn Title="Status" Align="Align.Center">
            <CellTemplate Context="context">
                <MudIcon Icon="@Icons.Material.Filled.Circle"
                         Color="@(context.Item.IsActive ? Color.Success : Color.Default)"
                         Size="Size.Small" />
            </CellTemplate>
        </TemplateColumn>

        <!-- ACTIONS -->
        <TemplateColumn Title="Actions" Align="Align.Right">
            <CellTemplate Context="context">
                <MudStack Row Justify="Justify.FlexEnd" Spacing="1">

                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="@(() => OpenEditDialog(context.Item))" />

                    <MudIconButton Icon="@Icons.Material.Outlined.History"
                                   Size="Size.Small" />

                    <MudIconButton Icon="@Icons.Material.Outlined.Inventory"
                                   Size="Size.Small" />

                </MudStack>
            </CellTemplate>
        </TemplateColumn>

    </Columns>

    <PagerContent>
        <MudDataGridPager T="PartDto" />
    </PagerContent>

</MudDataGrid>
@code {
    [Parameter] public bool ReloadTrigger { get; set; }
    private List<PartDto> PartsList = new();
    private string _searchString = "";
    private bool _loading = true;
    private bool _lastReloadTrigger;

    protected override async Task OnParametersSetAsync()
    {
        if (_lastReloadTrigger != ReloadTrigger)
        {
            _lastReloadTrigger = ReloadTrigger;
            await LoadDataInventory();
        }
    }
    protected override async Task OnInitializedAsync()
    {
        await LoadDataInventory();
    }
    public async Task LoadDataInventory()
    {
        try
        {
            _loading = true;

            PartsList = await InventoryClient.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al sincronizar con el servidor", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
    // Lógica de búsqueda rápida de MudBlazor
    private Func<PartDto, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        if (x.Sku.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    };



    private async Task OpenEditDialog(PartDto part)
    {
        // 1. Mapeamos el DTO al modelo de edición
        var updateRequest = new UpdatePartRequest
        {
            Id = part.Id,
            Sku = part.Sku,
            Name = part.Name,
            Brand = part.Brand,
            CategoryId = part.CategoryId,
            Price = part.Price,
            UnitOfMeasure = part.UnitOfMeasure,
            Stock = part.Stock,
            MinStock = part.MinStock,
            WarehouseLocation = part.WarehouseLocation,
            IsActive = part.IsActive
        };

        var parameters = new DialogParameters<EditPartDialog>
        {
            { x => x.InitialData, updateRequest }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            BackdropClick = false // Evita que se cierre por error al dar click fuera
        };

        var dialog = await DialogService.ShowAsync<EditPartDialog>(" ", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            Snackbar.Add("Parte actualizada correctamente", Severity.Success);
            await LoadDataInventory();
        }
    }
}