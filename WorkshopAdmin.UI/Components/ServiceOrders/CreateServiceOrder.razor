@page "/service-orders/create"

@using WorkshopAdmin.Shared.Dtos.Customers
@using WorkshopAdmin.Shared.Dtos.Equipments
@using WorkshopAdmin.Shared.Dtos.ServiceOrders
@using WorkshopAdmin.Shared.Enums
@using WorkshopAdmin.UI.Components.Clients
@using WorkshopAdmin.UI.Components.Equipment
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudForm @ref="_form">

    <main class="container" style="max-width:1440px;">

        <!-- ===================== -->
        <!-- ENTITY + ASSET -->
        <!-- ===================== -->
        <section class="bg-white border rounded shadow-sm overflow-hidden mb-4">

            <!-- HEADER -->
            <div class="bg-light px-3 py-2 border-bottom d-flex align-items-center">
                <h3 class="fw-bold text-uppercase d-flex align-items-center gap-2 m-0" style="font-size:14px; color:#000666;">
                    <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" />
                    Entity & Asset Selection
                </h3>
            </div>

            <div class="row g-3 p-3">

                <!-- ===================== -->
                <!-- CUSTOMER -->
                <!-- ===================== -->
                <div class="col-12 col-md-6">

                    <!-- HEADER -->
                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <label class="text-uppercase fw-bold text-muted" style="font-size:11px;">
                            Customer Selection
                        </label>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenCreateCustomerDialog"
                                   Class="fw-bold"
                                   Style="font-size:11px;">
                            New Customer
                        </MudButton>
                    </div>

                    <!-- INPUT -->
                    <MudAutocomplete T="CustomerDto"
                                     Value="_selectedCustomer"
                                     ValueChanged="OnCustomerChanged"
                                     SearchFunc="SearchCustomers"
                                     ToStringFunc="@(c => c?.Name)"
                                     Variant="Variant.Outlined"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                     Placeholder="Search by name, ID or phone..."
                                     Class="w-100"
                                     Required="true" />

                    <!-- CARD -->
                    <div class="bg-light rounded border p-3 d-flex align-items-center gap-3 mt-3">

                        <!-- ICON -->
                        <div class="border rounded d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:48px; height:48px; background:white;">
                            <MudIcon Icon="@Icons.Material.Filled.Business"
                                     Style="color:#000666;" />
                        </div>

                        <!-- INFO -->
                        <div class="flex-grow-1 overflow-hidden">
                            @if (_selectedCustomer != null)
                            {
                                <div class="fw-bold text-truncate" style="color:#000666;">
                                    @_selectedCustomer.Name
                                </div>

                                <div class="text-muted" style="font-size:11px;">
                                    ID: @_selectedCustomer.Id.ToString()[..8]
                                </div>
                            }
                            else
                            {
                                <div class="text-muted">
                                    No customer selected
                                </div>
                            }
                        </div>

                        <!-- ACTION -->
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small">
                            Change
                        </MudButton>

                    </div>

                </div>

                <!-- ===================== -->
                <!-- EQUIPMENT -->
                <!-- ===================== -->
                <div class="col-12 col-md-6">

                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <label class="text-uppercase fw-bold text-muted" style="font-size:11px;">
                            Equipment Selection
                        </label>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   OnClick="OpenCreateEquipmentDialog"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Style="font-size:11px;">
                            Register Equipment
                        </MudButton>
                    </div>

                    <!-- SELECT -->
                    <MudSelect T="Guid"
                               @bind-Value="_request.EquipmentId"
                               Variant="Variant.Outlined"
                               Disabled="@(_selectedCustomer == null)"
                               Required="true"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.QrCodeScanner"
                               Class="w-100">

                        @foreach (var eq in _customerEquipments)
                        {
                            <MudSelectItem Value="@eq.Id">
                                @eq.Brand @eq.Model
                            </MudSelectItem>
                        }

                    </MudSelect>

                    <!-- CARD -->
                    <div class="bg-light rounded border p-3 d-flex align-items-center gap-3 mt-3">

                        <div class="border rounded d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:48px; height:48px; background:white;">
                            <MudIcon Icon="@Icons.Material.Filled.Construction" Color="Color.Primary" />
                        </div>

                        <div class="flex-grow-1 overflow-hidden">
                            @if (_request.EquipmentId != Guid.Empty)
                            {
                                var eq = _customerEquipments.FirstOrDefault(x => x.Id == _request.EquipmentId);

                                <div class="fw-bold text-truncate" style="color:#000666;">
                                    @eq?.Brand @eq?.Model
                                </div>

                                <div class="text-muted" style="font-size:11px;">
                                    SN: --- • ---
                                </div>
                            }
                            else
                            {
                                <div class="text-muted">
                                    No equipment selected
                                </div>
                            }
                        </div>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small">
                            Change
                        </MudButton>

                    </div>

                </div>

            </div>

        </section>

        <!-- ===================== -->
        <!-- SERVICE -->
        <!-- ===================== -->
        <section class="bg-white border rounded shadow-sm overflow-hidden mb-4">

            <div class="bg-light px-3 py-2 border-bottom">
                <h3 class="fw-bold text-uppercase d-flex align-items-center gap-2 m-0"
                    style="font-size:14px; color:#000666;">
                    <MudIcon Icon="@Icons.Material.Filled.Handyman" Size="Size.Small" />
                    Service Details
                </h3>
            </div>

            <div class="p-3">

                <!-- SERVICE TYPE -->
                <div class="mb-4">
                    <label class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size:11px;">
                        Service Type
                    </label>

                    <div class="row g-2">
                        @foreach (var type in Enum.GetValues<ServiceType>())
                        {
                            var selected = _request.ServiceTypeId == type;

                            <div class="col-6 col-md">
                                <button type="button"
                                        class="w-100 btn @(selected ? "btn-primary" : "btn-outline-secondary")"
                                        style="font-size:11px;"
                                        @onclick="() => _request.ServiceTypeId = type">

                                    @type.ToFriendlyName().ToUpper()

                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- DESCRIPTION -->
                <div>
                    <label class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size:11px;">
                        Failure Description
                    </label>

                    <MudTextField T="string"
                                  @bind-Value="_request.FailureDescription"
                                  Variant="Variant.Outlined"
                                  Lines="8"
                                  Class="w-100"
                                  Required="true" />
                </div>

            </div>

        </section>

    </main>

    <!-- ===================== -->
    <!-- FOOTER -->
    <!-- ===================== -->
    <footer class="bg-white border-top p-3 d-flex justify-content-end shadow">

        <div class="d-flex gap-3">

            <MudButton Variant="Variant.Text">
                Cancel
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save">
                Save
            </MudButton>

        </div>

    </footer>

    <div style="height:80px;"></div>

</MudForm>
@code {

    private MudForm? _form;

    private CreateServiceOrderRequest _request = new();

    private CustomerDto? _selectedCustomer;

    private List<EquipmentDto> _customerEquipments = new();

    //  CAMBIO IMPORTANTE: manejar cambio explícito
    private async Task OnCustomerChanged(CustomerDto? value)
    {
        _selectedCustomer = value;

        _request.CustomerId = value?.Id ?? Guid.Empty;
        _request.EquipmentId = Guid.Empty;

        _customerEquipments.Clear();

        if (value != null)
        {
            await LoadEquipments(value.Id);
        }
    }

    //  DATA FAKE REALISTA
    private Task<IEnumerable<CustomerDto>> SearchCustomers(string value, CancellationToken token)
    {
        var data = new List<CustomerDto>
        {
            new() { Id = Guid.NewGuid(), Name = "Constructora Horizon", Phone = "555-1111" },
            new() { Id = Guid.NewGuid(), Name = "Minera San Juan", Phone = "555-2222" },
            new() { Id = Guid.NewGuid(), Name = "Logística S.A.", Phone = "555-3333" }
        };

        var result = data
            .Where(x => string.IsNullOrWhiteSpace(value)
                     || x.Name.Contains(value, StringComparison.OrdinalIgnoreCase));

        return Task.FromResult(result);
    }

    private async Task LoadEquipments(Guid customerId)
    {
        await Task.Delay(300); // simula API

        _customerEquipments = new List<EquipmentDto>
        {
            new() { Id = Guid.NewGuid(), Brand = "Caterpillar", Model = "320G" },
            new() { Id = Guid.NewGuid(), Brand = "Volvo", Model = "FH16" }
        };
    }

    private async Task SubmitOrder()
    {
        await _form!.Validate();

        if (!_form.IsValid)
        {
            Snackbar.Add("Complete all required fields", Severity.Warning);
            return;
        }

        //  aquí iría tu API
        await Task.Delay(500);

        Snackbar.Add("Service Order Created", Severity.Success);
    }
    private async Task OpenCreateCustomerDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<CreateCustomerDialog>(" ", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CreateCustomerRequest newClient)
        {
            try
            {
                // Aquí es donde conectas con tu servicio de aplicación
                // await CustomerService.CreateAsync(newClient);
                
                Snackbar.Add($"Client {newClient.Name} added to the system.", Severity.Success);
                
                // Opcional: Recargar la lista de la tabla
                // await LoadClients();
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error saving client: " + ex.Message, Severity.Error);
            }
        }
    }
    private async Task OpenCreateEquipmentDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<CreateEquipmentDialog>(" ", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CreateEquipmentRequest newEquipment)
        {
            try
            {
                // Aquí es donde conectas con tu servicio de aplicación
                // await CustomerService.CreateAsync(newEquipment);
                
                Snackbar.Add($"Equipment {newEquipment.DescriptionType} added to the system.", Severity.Success);
                
                // Opcional: Recargar la lista de la tabla
                // await LoadClients();
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error saving part: " + ex.Message, Severity.Error);
            }
        }
    }
}