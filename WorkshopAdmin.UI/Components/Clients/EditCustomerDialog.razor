@using WorkshopAdmin.Shared.Dtos.Customers
@using MudBlazor

<MudDialog Class="custom-industrial-dialog">
    <TitleContent>
        <div class="d-flex align-items-center gap-4 py-3 px-1">
            <div class="p-3 rounded" style="background-color: rgba(255,255,255,0.15);">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Inherit" Size="Size.Large" />
            </div>
            <div>
                <MudText Typo="Typo.h6" Class="fw-bold text-white text-uppercase">
                    Editar Cliente
                </MudText>
                <MudText Typo="Typo.caption" Class="text-white-50">
                    Actualice la información técnica del cliente
                </MudText>
            </div>
        </div>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid" Class="pt-4">
            <MudStack Spacing="4">

                <!-- NOMBRE -->
                <div class="mb-2">
                    <MudText Typo="Typo.caption" Class="fw-bold text-uppercase text-secondary d-flex align-items-center gap-1">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" />
                        NOMBRE COMPLETO
                    </MudText>

                    <MudTextField T="string"
                                  @bind-Value="_model.Name"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="Ingrese nombre del cliente" />
                </div>

                <MudGrid Spacing="2">

                    <!-- EMAIL -->
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="fw-bold text-uppercase text-secondary d-flex align-items-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" />
                            EMAIL
                        </MudText>

                        <MudTextField T="string"
                                      @bind-Value="_model.Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="correo@ejemplo.com" />
                    </MudItem>

                    <!-- PHONE -->
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="fw-bold text-uppercase text-secondary d-flex align-items-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.PhoneIphone" Size="Size.Small" />
                            TELÉFONO
                        </MudText>

                        <MudTextField T="string"
                                      @bind-Value="_model.Phone"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="+XX XXX XXX XXX" />
                    </MudItem>

                </MudGrid>

                <!-- SWITCH -->
                <div class="mt-4 p-4 rounded border d-flex align-items-center justify-content-between bg-light">
                    
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 rounded-circle bg-light">
                            <MudIcon Icon="@Icons.Material.Filled.VerifiedUser"
                                     Color="Color.Primary"
                                     Size="Size.Small" />
                        </div>

                        <div>
                            <MudText Typo="Typo.body2" Class="fw-bold">
                                Estado de la Cuenta
                            </MudText>

                            <MudText Typo="Typo.caption" Class="text-secondary">
                                Define si el cliente puede solicitar servicios
                            </MudText>
                        </div>
                    </div>

                    <MudSwitch @bind-Value="_model.IsActive" Color="Color.Primary" />
                </div>

            </MudStack>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <div class="px-4 pb-4 d-flex gap-3 w-100 justify-content-end">

            <MudButton OnClick="Cancel"
                       Variant="Variant.Text"
                       Class="px-4 fw-bold text-secondary">
                Cancelar
            </MudButton>

            <MudButton OnClick="Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(!_isValid)"
                       StartIcon="@Icons.Material.Filled.Save"
                       Class="px-4 fw-bold shadow">
                Actualizar Cliente
            </MudButton>

        </div>
    </DialogActions>

</MudDialog>

<style>
    .industrial-dialog .mud-dialog-title {
        background-color: #1a237e; /* Primary Container color */
        color: white;
        padding: 0 24px;
    }
    .industrial-gradient-bar {
        height: 4px;
        background: linear-gradient(90deg, #000666 0%, #4c56af 50%, #5c1800 100%);
    }
    .text-white-50 { color: rgba(255,255,255,0.7); }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    // Recibimos el objeto para editar
    [Parameter] public UpdateCustomerRequest InitialData { get; set; } = new();

    private UpdateCustomerRequest _model = new();
    private MudForm _form = default!;
    private bool _isValid;

    protected override void OnInitialized()
    {
        // Clonamos los datos para no modificar la lista original hasta que se guarde
        _model = new UpdateCustomerRequest
        {
            Id = InitialData.Id,
            Name = InitialData.Name,
            Email = InitialData.Email,
            Phone = InitialData.Phone,
            IsActive = InitialData.IsActive
        };
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (_isValid)
            MudDialog.Close(DialogResult.Ok(_model));
    }
}