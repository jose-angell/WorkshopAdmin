@* Components/Clients/ClientStats.razor *@
<MudGrid Class="mb-4">

    @* Card: New Clients *@
    <MudItem xs="12" sm="6">
        <MudPaper Elevation="1"
                  Class="p-4 rounded-4 border d-flex justify-content-between align-items-start"
                  Style="background-color: var(--mud-palette-surface);">

            <!-- LEFT CONTENT -->
            <div>

                <!-- LABEL -->
                <MudText Typo="Typo.overline"
                         Class="text-uppercase fw-bold mb-2"
                         Style="color: var(--mud-palette-text-secondary);">
                    New Clients (Monthly)
                </MudText>

                <!-- VALUE -->
                <MudText Typo="Typo.h4"
                         Class="fw-bold"
                         Style="color: var(--mud-palette-primary);">
                    +24
                </MudText>

                <!-- TREND -->
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Class="mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp"
                             Color="Color.Success"
                             Size="Size.Small" />

                    <MudText Typo="Typo.caption"
                             Class="fw-bold"
                             Style="color: var(--mud-palette-success);">
                        12% increase from last month
                    </MudText>
                </MudStack>

            </div>

            <!-- RIGHT ICON -->
            <MudPaper Class="p-3 rounded d-flex"
                      Style="background-color: rgba(0, 10, 143, 0.15); color: var(--mud-palette-primary);">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" />
            </MudPaper>

        </MudPaper>
    </MudItem>


    @* Card: Service Retention *@
    <MudItem xs="12" sm="6">
        <MudPaper Elevation="1"
                  Class="p-4 rounded-4 border d-flex justify-content-between align-items-start"
                  Style="background-color: var(--mud-palette-surface);">

            <!-- LEFT CONTENT -->
            <div class="w-100">

                <!-- LABEL -->
                <MudText Typo="Typo.overline"
                         Class="text-uppercase fw-bold mb-2"
                         Style="color: var(--mud-palette-text-secondary);">
                    Service Retention
                </MudText>

                <!-- VALUE -->
                <MudText Typo="Typo.h4"
                         Class="fw-bold"
                         Style="color: var(--mud-palette-primary);">
                    88.4%
                </MudText>

                <!-- PROGRESS -->
                <MudProgressLinear Value="88.4"
                                   Color="Color.Primary"
                                   Class="mt-3"
                                   Rounded="true" />

            </div>

            <!-- RIGHT ICON -->
            <MudPaper Class="p-3 rounded d-flex"
                      Style="background-color: rgba(0, 10, 143, 0.15); color: var(--mud-palette-primary);">
                <MudIcon Icon="@Icons.Material.Filled.Verified" />
            </MudPaper>

        </MudPaper>
    </MudItem>

</MudGrid>